# Copy to `.env` in this directory. Playwright loads it via playwright.config.ts (dotenv).

# RHAAP sign-in — admin user (browser)
AAP_USER_ID=<your-aap-admin-username>
AAP_USER_PASS=<your-aap-admin-password>

# RHAAP sign-in — non-admin user (for permission boundary tests)
# This user should have Org Member role + Execute on specific job templates
AAP_NONADMIN_USER_ID=<your-aap-nonadmin-username>
AAP_NONADMIN_USER_PASS=<your-aap-nonadmin-password>

# Portal under test (Playwright baseURL)
BASE_URL=http://localhost:7071

# AAP controller base URL — must match auth.providers.rhaap.development.host in app-config
AAP_URL=https://34.226.249.151

# OAuth client id for this portal (auth-aap-first / buildAapOAuthAuthorizeUrl only).
# Must match auth.providers.rhaap.development.clientId — not the secret.
OAUTH_CLIENT_ID=<your-oauth-client-id>

# Optional: scope for /o/authorize/ (default: read)
# OAUTH_SCOPE=read

# Optional: EE template import (ee02-template-execution.spec.ts)
EE_IMPORT_REPO_URL=https://github.com/ansible/ansible-rhdh-templates/blob/main/templates/ee-cloud-automation.yaml

# AAP API token (admin) — required for non-admin user creation/teardown via AAP API
# AAP_TOKEN=<your-aap-api-token>

# AAP organization name — the org the non-admin user should be added to
# Must match catalog.providers.rhaap.development.orgs in app-config
# AAP_ORG_NAME=<your-aap-org-name>

# RHDH / GitHub (when using migrated rhdh Playwright specs)
# GH_USER_ID=<github-username>
# GH_USER_PASS=<github-password>
# AUTHENTICATOR_SECRET=<base32-totp-secret>
