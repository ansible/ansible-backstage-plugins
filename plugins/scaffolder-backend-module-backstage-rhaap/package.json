{
  "name": "@ansible/plugin-scaffolder-backend-module-backstage-rhaap",
  "description": "The ansible backend module for the backstage scaffolder plugin.",
  "version": "2.1.1",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "backend-plugin-module",
    "pluginId": "scaffolder",
    "pluginPackage": "@backstage/plugin-scaffolder-backend"
  },
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "fix": "backstage-cli repo fix --publish",
    "export-dynamic": "rhdh-cli plugin export --embed-package @ansible/backstage-rhaap-common"
  },
  "dependencies": {
    "@ansible/backstage-rhaap-common": "workspace:^",
    "@backstage/backend-defaults": "^0.16.0",
    "@backstage/backend-dynamic-feature-service": "^0.7.6",
    "@backstage/backend-plugin-api": "^1.5.0",
    "@backstage/catalog-model": "^1.7.6",
    "@backstage/config": "^1.3.6",
    "@backstage/errors": "^1.2.7",
    "@backstage/integration": "^1.18.2",
    "@backstage/plugin-catalog-import": "^0.13.7",
    "@backstage/plugin-scaffolder": "^1.34.3",
    "@backstage/plugin-scaffolder-backend": "^3.3.0",
    "@backstage/plugin-scaffolder-node": ">=0.11.0 <0.13.0",
    "@backstage/types": "^1.2.2",
    "@octokit/core": "^5.0.0",
    "express": "^5.1.0",
    "express-promise-router": "^4.1.1",
    "isomorphic-git": "^1.23.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^2.6.7",
    "semver": "^7.7.3",
    "undici": "6.23.0",
    "yaml": "^2.0.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0"
  },
  "devDependencies": {
    "@backstage/backend-test-utils": "^1.10.0",
    "@backstage/cli": "^0.34.5",
    "@backstage/plugin-scaffolder-node-test-utils": "^0.3.5",
    "@backstage/test-utils": "^1.7.13",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4",
    "@types/node": "^22.13.4",
    "@types/node-fetch": "2.6.11",
    "@types/semver": "^7",
    "dedent": "^1.7.0",
    "msw": "2.4.9",
    "supertest": "^7.1.4"
  },
  "files": [
    "dist",
    "dist-dynamic/*.*",
    "dist-dynamic/dist/**",
    "dist-dynamic/alpha/*",
    "build",
    "src/**/*.d.ts"
  ],
  "configSchema": "config.d.ts"
}
